rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Core Helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- MEMBERS COLLECTION ---
    function isValidPlayer(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 128
        && data.officialName is string && data.officialName.size() <= 128
        && (!('nickname' in data) || data.nickname == null || (data.nickname is string && data.nickname.size() <= 128))
        && (!('avatarUrl' in data) || data.avatarUrl == null || (data.avatarUrl is string && data.avatarUrl.size() <= 1000000));
    }

    match /members/{memberId} {
      allow read: if true;
      allow create, update: if isValidId(memberId) && isValidPlayer(incoming());
      allow delete: if isValidId(memberId);
    }

    // --- GAMES COLLECTION ---
    function isValidSavedGame(data) {
      return data.id is string && data.id.size() <= 128
        && data.players is list && data.players.size() <= 20
        && data.rounds is list && data.rounds.size() <= 1000
        && data.date is string && data.date.size() <= 128
        && data.winnerName is string && data.winnerName.size() <= 128;
    }

    match /games/{gameId} {
      allow read: if true;
      allow create, update: if isValidId(gameId) && isValidSavedGame(incoming());
      allow delete: if isValidId(gameId);
    }

    // --- ACTIVE TABLE ---
    function isValidActiveTable(data) {
      return data.players is list && data.players.size() <= 20
        && data.rounds is list && data.rounds.size() <= 1000
        && data.status is string && (data.status == 'setup' || data.status == 'playing' || data.status == 'ended')
        && (!('lastAutoSavedTime' in data) || data.lastAutoSavedTime == null || (data.lastAutoSavedTime is string && data.lastAutoSavedTime.size() <= 128))
        && (!('updatedAt' in data) || data.updatedAt == null || (data.updatedAt is string && data.updatedAt.size() <= 128));
    }

    match /active_table/{docId} {
      allow read, write: if true;
    }
  }
}
