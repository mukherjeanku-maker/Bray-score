{
  "entities": {
    "Player": {
      "title": "Player",
      "description": "A registered clubhouse member or temporary player profile.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique profile ID"
        },
        "name": {
          "type": "string",
          "description": "Display name"
        },
        "officialName": {
          "type": "string",
          "description": "Official name on register"
        },
        "nickname": {
          "type": "string",
          "description": "Optional short name"
        },
        "avatarUrl": {
          "type": "string",
          "description": "Optional avatar image URL or Data URL"
        }
      },
      "required": ["id", "name", "officialName"]
    },
    "Round": {
      "title": "Round",
      "description": "Scores registered for each active player in a game round.",
      "type": "object",
      "properties": {
        "roundNumber": {
          "type": "integer"
        },
        "scores": {
          "type": "object",
          "description": "A map of playerId to numerical score"
        }
      },
      "required": ["roundNumber", "scores"]
    },
    "SavedGame": {
      "title": "SavedGame",
      "description": "A historical archived card match record.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "players": {
          "type": "array",
          "items": { "type": "object" }
        },
        "rounds": {
          "type": "array",
          "items": { "type": "object" }
        },
        "date": {
          "type": "string"
        },
        "winnerName": {
          "type": "string"
        }
      },
      "required": ["id", "players", "rounds", "date", "winnerName"]
    },
    "ActiveTable": {
      "title": "ActiveTable",
      "description": "The current live active card table state playing in the clubhouse.",
      "type": "object",
      "properties": {
        "players": {
          "type": "array",
          "items": { "type": "object" }
        },
        "rounds": {
          "type": "array",
          "items": { "type": "object" }
        },
        "status": {
          "type": "string",
          "enum": ["setup", "playing", "ended"]
        },
        "lastAutoSavedTime": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string"
        }
      },
      "required": ["players", "rounds", "status"]
    }
  },
  "firestore": {
    "members/{memberId}": {
      "schema": "Player",
      "description": "Active club directory database profiles."
    },
    "games/{gameId}": {
      "schema": "SavedGame",
      "description": "Match history archive of completed hands."
    },
    "active_table/{docId}": {
      "schema": "ActiveTable",
      "description": "Single-document storage sync of the current live play sessions."
    }
  }
}
