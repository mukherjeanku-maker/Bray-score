{
  "entities": {
    "Player": {
      "title": "Player",
      "description": "Club member or guest playing at the card table",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique profile ID" },
        "name": { "type": "string", "description": "Display name" },
        "officialName": { "type": "string", "description": "Official legal name" },
        "nickname": { "type": "string", "description": "Member nickname" },
        "avatarUrl": { "type": "string", "description": "Avatar base64 or URL" }
      },
      "required": ["id", "name", "officialName"]
    },
    "Round": {
      "title": "Round",
      "description": "Scoring round details",
      "type": "object",
      "properties": {
        "roundNumber": { "type": "integer" },
        "scores": { "type": "object", "description": "Map of player ID to score in this round" }
      },
      "required": ["roundNumber", "scores"]
    },
    "CompletedGame": {
      "title": "CompletedGame",
      "description": "A historic completed card game session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "players": { "type": "array", "description": "List of players in their final states" },
        "rounds": { "type": "array", "description": "Rounds and scores played in the game" },
        "date": { "type": "string", "format": "date-time" },
        "winnerName": { "type": "string" }
      },
      "required": ["id", "players", "rounds", "date", "winnerName"]
    },
    "ActiveSession": {
      "title": "ActiveSession",
      "description": "The current live status of the active card table",
      "type": "object",
      "properties": {
        "players": { "type": "array" },
        "rounds": { "type": "array" },
        "status": { "type": "string", "enum": ["setup", "playing", "ended"] },
        "lastAutoSavedTime": { "type": "string" }
      },
      "required": ["players", "rounds", "status"]
    }
  },
  "firestore": {
    "players/{playerId}": {
      "schema": "Player",
      "description": "Permanent directory of club members"
    },
    "history/{gameId}": {
      "schema": "CompletedGame",
      "description": "Completed games archive logs"
    },
    "activeSession/current": {
      "schema": "ActiveSession",
      "description": "The current live session of the active card table"
    }
  }
}
